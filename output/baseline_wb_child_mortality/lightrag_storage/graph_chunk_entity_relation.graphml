  <data key="d0">AFE</data>
  <data key="d1">organization</data>
  <data key="d2">AFE (Africa Eastern and Southern) is a regional organization that tracks health indicators including under-5 mortality rates across member regions.</data>
  <data key="d3">chunk-751c4fa9fccb24615796a3d460934d66&lt;SEP&gt;chunk-0620180a3af2e5b49de52aacd5e7206b</data>
